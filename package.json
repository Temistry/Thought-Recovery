{
  "name": "idea-second-brain",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.108.0",
    "base64-arraybuffer": "^1.0.2",
    "expo": "~54.0.0",
    "expo-av": "~16.0.8",
    "expo-calendar": "~15.0.8",
    "expo-clipboard": "~8.0.8",
    "expo-file-system": "~19.0.23",
    "expo-haptics": "~15.0.8",
    "expo-speech-recognition": "^3.1.3",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "postinstall": "node scripts/fix-metro-watch.js",
    "typecheck": "tsc --noEmit",
    "desktop:dev": "npm run dev --workspace @idea-second-brain/desktop",
    "desktop:build": "npm run build --workspace @idea-second-brain/desktop",
    "desktop:exe": "npm run dist:exe --workspace @idea-second-brain/desktop",
    "desktop:clean": "node scripts/clean-desktop-release.cjs"
  },
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
